# Prisma / Supabase PostgreSQL connection
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# API key for the paper ingestion endpoint (POST /api/papers)
API_KEY="your-secret-api-key"

# Admin password for triggering the pipeline from the UI
ADMIN_PASSWORD="your-admin-password"

# URL of the pipeline backend (Lambda function URL, API Gateway, etc.)
PIPELINE_URL="https://your-lambda-function-url.lambda-url.us-east-1.on.aws/"

# AWS credentials for signing Lambda function URL requests
PIPELINE_AWS_ACCESS_KEY_ID=""
PIPELINE_AWS_SECRET_ACCESS_KEY=""
PIPELINE_AWS_REGION="us-east-1"
